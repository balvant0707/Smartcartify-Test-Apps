model LineItemMessaging {
  id              Int       @id @default(autoincrement())
  shop            String    @db.VarChar(255)
  name            String    @db.VarChar(255)
  status          String    @default("draft") @db.VarChar(20)
  targetType      String    @default("all") @db.VarChar(32)
  targetIds       String?   @db.LongText
  conditions      String?   @db.LongText
  conditionMatch  String    @default("all") @db.VarChar(8)
  messageTemplate String    @default("delivery") @db.VarChar(32)
  customMessage   String?   @db.Text
  position        String    @default("below") @db.VarChar(8)
  bgColor         String?   @db.VarChar(32)
  textColor       String?   @db.VarChar(32)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
