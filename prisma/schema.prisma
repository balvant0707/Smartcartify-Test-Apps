model CartAutomation {
  id                        Int       @id @default(autoincrement())
  shop                      String    @db.VarChar(255)
  name                      String    @db.VarChar(255)
  status                    String    @default("draft") @db.VarChar(20)
  triggerRules              String    @db.LongText
  triggerMatch              String    @default("any") @db.VarChar(8)
  hasConditions             Boolean   @default(false)
  conditionType             String?   @db.VarChar(32)
  conditionValue            String?   @db.VarChar(255)
  actionType                String    @default("add_attribute") @db.VarChar(32)
  attrKey                   String?   @db.VarChar(255)
  attrValue                 String?   @db.VarChar(255)
  redirectUrl               String?   @db.VarChar(512)
  redirectDelay             String?   @db.VarChar(8)
  showMessage               String?   @db.Text
  autoAddProductId          String?   @db.VarChar(255)
  autoAddQty                String?   @db.VarChar(8)
  autoRemoveWhenTriggerLost Boolean   @default(true)
  runOnce                   Boolean   @default(false)
  startsAt                  DateTime?
  endsAt                    DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([shop])
  @@map("cartautomation")
}
