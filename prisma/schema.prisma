generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String    @db.VarChar(255)
  state         String    @db.VarChar(255)
  isOnline      Boolean   @default(false)
  scope         String?   @db.VarChar(1024)
  expires       DateTime?
  accessToken   String    @db.Text
  userId        BigInt?
  firstName     String?   @db.VarChar(255)
  lastName      String?   @db.VarChar(255)
  email         String?   @db.VarChar(320)
  accountOwner  Boolean   @default(false)
  locale        String?   @db.VarChar(32)
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
  @@map("session")
}

model shop {
  id                Int       @id @default(autoincrement())
  shop              String    @unique @db.VarChar(255)
  accessToken       String?   @db.Text
  installed         Boolean   @default(false)
  uninstalledAt     DateTime?
  onboardedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  firstName         String?   @db.VarChar(255)
  lastName          String?   @db.VarChar(255)
  name              String?   @db.VarChar(255)
  ownerName         String?   @db.VarChar(255)
  email             String?   @db.VarChar(320)
  domain            String?   @db.VarChar(255)
  contactNumber     String?   @db.VarChar(50)
  phone             String?   @db.VarChar(50)
  city              String?   @db.VarChar(255)
  country           String?   @db.VarChar(255)
  currency          String?   @db.VarChar(10)
  appStatus         String    @default("active") @db.VarChar(20)
  status            String    @default("installed") @db.VarChar(20)
  reviewSubmittedAt DateTime?
  reviewRating      Int?
  reviewComment     String?   @db.Text

  @@map("shop")
}

model ShippingRule {
  id                        Int       @id @default(autoincrement())
  shop                      String
  rewardType                String
  rateType                  String?
  amount                    String?
  minSubtotal               String?
  maxSubtotal               String?
  method                    String
  enabled                   Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  iconChoice                String?   @default("truck")
  shopifyRateId             String?   @db.VarChar(255)
  shopifyMethodDefinitionId String?   @db.VarChar(255)
  progressTextBefore        String?   @db.Text
  progressTextAfter         String?   @db.Text
  progressTextBelow         String?   @db.Text
  campaignName              String?   @db.VarChar(255)
  cartStepName              String?   @db.VarChar(255)
  startsAt                  DateTime?
  endsAt                    DateTime?
  priority                  Int       @default(0)
  customerTarget            String    @default("all") @db.VarChar(32)
  customerTags              String?   @db.LongText
  templateKey               String?   @db.VarChar(64)
  abTestEnabled             Boolean   @default(false)
  abTestVariant             String?   @db.VarChar(32)
  translations              String?   @db.LongText
  analyticsImpressions      Int       @default(0)
  analyticsConversions      Int       @default(0)

  @@index([shop])
  @@map("shippingrule")
}

model DiscountRule {
  id                         Int       @id @default(autoincrement())
  shop                       String
  type                       String
  value                      String?
  minPurchase                String?
  triggerType                String    @default("amount") @db.VarChar(32)
  minQuantity                String?
  enabled                    Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  iconChoice                 String?   @default("tag")
  shopifyDiscountCodeId      String?   @db.VarChar(255)
  shopifyPriceRuleId         String?   @db.VarChar(255)
  discountCode               String?   @db.VarChar(255)
  progressTextBefore         String?   @db.Text
  progressTextAfter          String?   @db.Text
  quantityProgressTextBefore String?   @db.Text
  quantityProgressTextAfter  String?   @db.Text
  progressTextBelow          String?   @db.Text
  campaignName               String?   @db.VarChar(255)
  cartStepName               String?   @db.VarChar(255)
  codeCampaignName           String?   @db.VarChar(255)
  valueType                  String    @default("percent")
  appliesTo                  String?   @db.LongText
  codeDiscountId             String?   @db.VarChar(255)
  condition                  String?   @db.VarChar(255)
  rewardType                 String    @default("percent")
  scope                      String?   @db.VarChar(255)
  startsAt                   DateTime?
  endsAt                     DateTime?
  priority                   Int       @default(0)
  customerTarget             String    @default("all") @db.VarChar(32)
  customerTags               String?   @db.LongText
  templateKey                String?   @db.VarChar(64)
  abTestEnabled              Boolean   @default(false)
  abTestVariant              String?   @db.VarChar(32)
  translations               String?   @db.LongText
  analyticsImpressions       Int       @default(0)
  analyticsConversions       Int       @default(0)

  @@index([shop])
  @@map("discountrule")
}

model FreeGiftRule {
  id                          Int       @id @default(autoincrement())
  shop                        String
  trigger                     String
  minPurchase                 String?
  triggerType                 String    @default("amount") @db.VarChar(32)
  minQuantity                 String?
  qty                         String?
  limitPerOrder               String?
  enabled                     Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  iconChoice                  String?   @default("gift")
  bonusProductId              String?   @db.VarChar(255)
  freeProductDiscountID       String?   @db.VarChar(255)
  minAmountFreeGiftDiscountId String?   @db.VarChar(255)
  minAmountShippingRateId     String?   @db.VarChar(255)
  allProductIds               String?   @db.LongText
  progressTextBefore          String?   @db.Text
  progressTextAfter           String?   @db.Text
  quantityProgressTextBefore  String?   @db.Text
  quantityProgressTextAfter   String?   @db.Text
  progressTextBelow           String?   @db.Text
  campaignName                String?   @db.VarChar(255)
  cartStepName                String?   @db.VarChar(255)
  startsAt                    DateTime?
  endsAt                      DateTime?
  priority                    Int       @default(0)
  customerTarget              String    @default("all") @db.VarChar(32)
  customerTags                String?   @db.LongText
  templateKey                 String?   @db.VarChar(64)
  abTestEnabled               Boolean   @default(false)
  abTestVariant               String?   @db.VarChar(32)
  translations                String?   @db.LongText
  analyticsImpressions        Int       @default(0)
  analyticsConversions        Int       @default(0)

  @@index([shop])
  @@map("freegiftrule")
}

model BxgyRule {
  id                       Int       @id @default(autoincrement())
  shop                     String
  xQty                     String
  yQty                     String
  scope                    String
  appliesTo                String?   @db.LongText
  giftType                 String
  giftSku                  String?   @db.LongText
  maxGifts                 String?
  allowStacking            Boolean   @default(false)
  enabled                  Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  iconChoice               String?   @default("sparkles")
  appliesCollectionIds     String?   @db.LongText
  appliesProductIds        String?   @db.LongText
  appliesStore             Boolean   @default(false)
  buyxgetyId               String?   @db.VarChar(255)
  afterOfferUnlockMessage  String?
  beforeOfferUnlockMessage String?
  campaignName             String?   @db.VarChar(255)
  status                   String    @default("draft") @db.VarChar(32)
  conditionType            String?   @db.VarChar(64)
  buyProductIds            String?   @db.LongText
  buyCollectionIds         String?   @db.LongText
  rewardProductIds         String?   @db.LongText
  minQuantity              String?   @db.VarChar(255)
  minSpend                 String?   @db.VarChar(255)
  maxUsesPerOrder          String?   @db.VarChar(255)
  startsAt                 DateTime?
  endsAt                   DateTime?
  priority                 Int       @default(0)
  customerTarget           String    @default("all") @db.VarChar(32)
  customerTags             String?   @db.LongText
  templateKey              String?   @db.VarChar(64)
  abTestEnabled            Boolean   @default(false)
  abTestVariant            String?   @db.VarChar(32)
  translations             String?   @db.LongText
  analyticsImpressions     Int       @default(0)
  analyticsConversions     Int       @default(0)

  @@index([shop])
  @@map("bxgyrule")
}

model CartGoalRule {
  id                       Int      @id @default(autoincrement())
  shop                     String   @db.VarChar(255)
  campaignName             String?  @db.VarChar(255)
  enabled                  Boolean  @default(false)
  trackBy                  String   @default("value") @db.VarChar(32)
  shownGoals               Int      @default(3)
  goals                    String   @db.LongText
  startDate                String?  @db.VarChar(32)
  startTime                String?  @db.VarChar(32)
  hasEndDate               Boolean  @default(false)
  endDate                  String?  @db.VarChar(32)
  endTime                  String?  @db.VarChar(32)
  showcaseFreeGifts        String   @default("hide") @db.VarChar(32)
  discountProgressMode     String   @default("after") @db.VarChar(32)
  rewardSelectionMandatory String   @default("yes") @db.VarChar(32)
  customerTarget           String   @default("all") @db.VarChar(32)
  customerTags             String?  @db.LongText
  targetingRules           String?  @db.LongText
  priority                 Int      @default(0)
  analyticsImpressions     Int      @default(0)
  analyticsConversions     Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([shop])
  @@map("cartgoalrule")
}

model StyleSettings {
  id                             Int      @id @default(autoincrement())
  shop                           String   @unique @db.VarChar(255)
  font                           String
  base                           String
  headingScale                   String
  radius                         String
  textColor                      String
  bg                             String
  progress                       String
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  cartDrawerBackground           String?
  cartDrawerTextColor            String?
  cartDrawerHeaderColor          String?
  cartIconType                   String?  @db.VarChar(32)
  cartDefaultIcon                String?  @db.VarChar(64)
  cartIconUrl                    String?
  discountCodeApply              Boolean  @default(false)
  cartDrawerImage                String?
  cartDrawerBackgroundMode       String   @default("color")
  cartDrawerGradientStart        String?  @db.VarChar(32)
  cartDrawerGradientEnd          String?  @db.VarChar(32)
  borderColor                    String?
  buttonColor                    String?
  checkoutButtonText             String?
  announcementBarBackgroundColor String?
  announcementBarTextColor       String?
  buttonLabelColor               String?
  iconColor                      String?
  drawerAutoOpen                 Boolean  @default(true)
  drawerPosition                 String   @default("right") @db.VarChar(32)
  stickyCheckout                 Boolean  @default(true)
  mobileLayout                   String   @default("drawer") @db.VarChar(32)
  offerButtonEnabled             Boolean  @default(true)
  progressBg                     String?  @db.VarChar(32)

  @@map("stylesettings")
}

model UpsellSettings {
  id                    Int      @id @default(autoincrement())
  shop                  String   @unique @db.VarChar(255)
  enabled               Boolean  @default(true)
  showAsSlider          Boolean  @default(true)
  autoplay              Boolean  @default(true)
  recommendationMode    String   @default("auto") @db.VarChar(32)
  sectionTitle          String?  @db.VarChar(255)
  buttonText            String?  @db.VarChar(255)
  buttonColor           String?  @db.VarChar(32)
  buttonTextColor       String?  @db.VarChar(32)
  backgroundColor       String?  @db.VarChar(32)
  textColor             String?  @db.VarChar(32)
  borderColor           String?  @db.VarChar(32)
  arrowColor            String?  @db.VarChar(32)
  selectedProductIds    String?  @db.LongText
  selectedCollectionIds String?  @db.LongText
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("upsellsettings")
}

model AddToCartBarSettings {
  id                            Int      @id @default(autoincrement())
  shop                          String   @unique @db.VarChar(255)
  status                        String   @default("active") @db.VarChar(20)

  // Mobile look & feel
  mobileShowCondition           String   @default("scrollDown") @db.VarChar(64)
  mobileScrollDepth             Int      @default(380)
  mobileStickyPosition          String   @default("bottom") @db.VarChar(16)
  mobileCtaAnimation            String   @default("pulse") @db.VarChar(32)
  mobileBgColor                 String?  @db.VarChar(32)
  mobileTextColor               String?  @db.VarChar(32)
  mobileCtaBgColor              String?  @db.VarChar(32)
  mobileCtaTextColor            String?  @db.VarChar(32)
  mobileImageOutlineColor       String?  @db.VarChar(32)
  mobileShowProductImage        Boolean  @default(true)
  mobileShowProductTitle        Boolean  @default(true)
  mobileShowPrice               Boolean  @default(true)
  mobileShowCompareAtPrice      Boolean  @default(true)
  mobileShowQuantity            Boolean  @default(true)
  mobileShowVariantSelector     Boolean  @default(true)
  mobileShowVariantLabel        Boolean  @default(true)
  mobileShowPriceOnCta          Boolean  @default(true)
  mobileShowCompareAtPriceOnCta Boolean  @default(true)

  // Desktop look & feel
  desktopShowCondition           String   @default("scrollDown") @db.VarChar(64)
  desktopScrollDepth             Int      @default(380)
  desktopStickyPosition          String   @default("bottom") @db.VarChar(16)
  desktopCtaAnimation            String   @default("pulse") @db.VarChar(32)
  desktopBgColor                 String?  @db.VarChar(32)
  desktopTextColor               String?  @db.VarChar(32)
  desktopCtaBgColor              String?  @db.VarChar(32)
  desktopCtaTextColor            String?  @db.VarChar(32)
  desktopImageOutlineColor       String?  @db.VarChar(32)
  desktopShowProductImage        Boolean  @default(true)
  desktopShowProductTitle        Boolean  @default(true)
  desktopShowPrice               Boolean  @default(true)
  desktopShowCompareAtPrice      Boolean  @default(true)
  desktopShowQuantity            Boolean  @default(true)
  desktopShowVariantSelector     Boolean  @default(true)
  desktopShowVariantLabel        Boolean  @default(true)
  desktopShowPriceOnCta          Boolean  @default(true)
  desktopShowCompareAtPriceOnCta Boolean  @default(true)

  // General settings
  ctaBehavior                   String   @default("addToCart") @db.VarChar(32)
  afterAddToCart                String   @default("openCartWidget") @db.VarChar(64)
  homepageProductId             String?  @db.VarChar(255)
  homepageProductTitle          String?  @db.VarChar(255)
  customCss                     String?  @db.LongText
  customJs                      String?  @db.LongText
  desktopZIndex                 Int      @default(5000)
  mobileZIndex                  Int      @default(5000)

  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@map("addtocartbarsettings")
}

model PlanSubscription {
  id                    Int       @id @default(autoincrement())
  shop                  String    @unique @db.VarChar(255)
  planId                String?   @db.VarChar(255)
  planName              String?   @db.VarChar(255)
  status                String?   @db.VarChar(45)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  currentPeriodEnd      DateTime?
  shopifySubGid         String?
  billingInterval       String?   @db.VarChar(32)
  billingAmount         Decimal?  @db.Decimal(10, 2)
  billingCurrency       String?   @db.VarChar(10)
  trialDays             Int?
  isTest                Boolean?
  subscriptionCreatedAt DateTime? @db.DateTime(0)

  @@map("plansubscription")
}
